# QuantumField Environment Variables
# Copy this file to .env.local and fill in values

# Public (exposed to client)
NEXT_PUBLIC_APP_NAME=QuantumField
NEXT_PUBLIC_MAX_PARTICLES_WEBGPU=2000000
NEXT_PUBLIC_MAX_PARTICLES_WEBGL=500000
NEXT_PUBLIC_DEFAULT_PARTICLE_COUNT=50000

# Server-only (never exposed to client)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_UPLOADS=10
